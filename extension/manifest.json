{
  "manifest_version": 3,
  "name": "Nephele Wisp",
  "version": "0.4.1",
  "description": "Browser-side companion for Nephele Workshop. Uses your real browser so platforms see you, not a bot.",
  "author": "ArisFusion",
  "homepage_url": "https://github.com/CreatorAris/nephele-wisp",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Nephele Wisp",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },
  "permissions": [
    "nativeMessaging",
    "storage",
    "debugger",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "*://*.bilibili.com/*",
    "*://*.xiaohongshu.com/*",
    "*://*.weibo.com/*",
    "*://*.weibo.cn/*",
    "*://*.douyin.com/*",
    "*://*.pixiv.net/*",
    "*://*.x.com/*",
    "*://*.twitter.com/*",
    "*://*.artstation.com/*",
    "http://127.0.0.1/*"
  ],
  "minimum_chrome_version": "116"
}
